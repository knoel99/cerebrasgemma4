# Cerebras Cloud API key — https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Demo mode: sub-60s pipeline (720p video + report screenshots, sparse frames)
SIGHTLINE_DEMO_MODE=1

# Hugging Face token — faster-whisper model downloads (read access is enough)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: local Whisper fallback when YouTube captions / GCP unavailable
WHISPER_MODEL=base